SMARTPOLICE_OFFLINE_FIRST=true
SMARTPOLICE_ENABLE_CLIP=1
SMARTPOLICE_CLIP_MODEL=backend/data/hf_models/openai_clip-vit-base-patch32
LOCAL_VISION_BASE_URL=http://127.0.0.1:1235/v1
LOCAL_VISION_MODEL=qwen/qwen3-vl-8b-instruct
SMARTPOLICE_ENABLE_LOCAL_VLM=0
SMARTPOLICE_REQUIRE_LOCAL_VISION=0

# Optional cloud review/report enhancement. The formal local-first path works without these keys.
SMARTPOLICE_ENABLE_CLOUD_REVIEW=0
SMARTPOLICE_ENABLE_CLOUD_REPORT=0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL_REASONING=deepseek-v4-pro
DEEPSEEK_MODEL_VERIFIER=deepseek-v4-pro

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL_ROUTER=MiniMax-M3
MINIMAX_MODEL_LONG_CONTEXT=MiniMax-M3
MINIMAX_MODEL_REPORT=MiniMax-M3

# Optional paid cloud vision enhancement. Leave disabled for offline/local competition runs.
ENABLE_DASHSCOPE=0
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus
